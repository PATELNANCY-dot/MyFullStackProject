@{
    ViewData["Title"] = "Manage Students";
}
<style>
    /* General page styling */
    body {
        font-family: Arial, sans-serif;
        background-color: #f7f8fa;
        color: #333;
        padding: 20px;
    }

    /* Headings */
    h2, h3 {
        color: #2c3e50;
    }

    /* Form styling */
    form#studentForm {
        background-color: #ffffff;
        padding: 20px;
        border-radius: 10px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        max-width: 400px;
        margin-bottom: 30px;
    }

    form#studentForm label {
        font-weight: bold;
    }

    form#studentForm input[type="text"] {
        width: 100%;
        padding: 8px 10px;
        margin: 6px 0 12px 0;
        border: 1px solid #ccc;
        border-radius: 6px;
        box-sizing: border-box;
        transition: border-color 0.3s;
    }

    form#studentForm input[type="text"]:focus {
        border-color: #3498db;
        outline: none;
    }

    /* Buttons */
    button {
        padding: 8px 16px;
        margin-right: 10px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        transition: background-color 0.3s, transform 0.2s;
    }

    #submitBtn {
        background-color: #3498db;
        color: white;
    }

    #submitBtn:hover {
        background-color: #2980b9;
        transform: translateY(-2px);
    }

    #cancelBtn {
        background-color: #e74c3c;
        color: white;
    }

    #cancelBtn:hover {
        background-color: #c0392b;
        transform: translateY(-2px);
    }

    /* Table styling */
    table#studentsTable {
        width: 100%;
        border-collapse: collapse;
        background-color: #fff;
        border-radius: 10px;
        overflow: hidden;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
    }

    table#studentsTable th, table#studentsTable td {
        padding: 12px 15px;
        text-align: left;
    }

    table#studentsTable thead {
        background-color: #3498db;
        color: white;
    }

    table#studentsTable tbody tr:nth-child(even) {
        background-color: #f2f2f2;
    }

    table#studentsTable button {
        background-color: #2ecc71;
        color: white;
        padding: 5px 10px;
        font-size: 14px;
    }

    table#studentsTable button:hover {
        background-color: #27ae60;
    }

    table#studentsTable button + button {
        margin-left: 5px;
        background-color: #e74c3c;
    }

    table#studentsTable button + button:hover {
        background-color: #c0392b;
    }

    /* Container for search bar */
    .search {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 10px 20px;
        font-family: Arial, sans-serif;
        color: #333;
    }

        /* Label styling */
        .search label {
            font-weight: bold;
            font-size: 16px;
        }

        /* Input box styling */
        .search input[type="text"] {
            padding: 8px 12px;
            font-size: 15px;
            border: 1px solid #ccc;
            border-radius: 6px;
            outline: none;
            transition: 0.3s;
            width: 250px;
        }

            /* Focus effect */
            .search input[type="text"]:focus {
                border-color: #007bff;
                box-shadow: 0 0 5px rgba(0,123,255,0.5);
            }

    /* Table styling */
    #studentsTable {
        width: 95%;
        margin: 10px 20px;
        border-collapse: collapse;
        font-family: Arial, sans-serif;
    }

        #studentsTable th, #studentsTable td {
            padding: 10px 12px;
            text-align: left;
        }

        #studentsTable th {
            background-color: #007bff;
            color: white;
        }

        #studentsTable tr:nth-child(even) {
            background-color: #f2f2f2;
        }

        #studentsTable tr:hover {
            background-color: #d0e7ff;
        }
</style>


<h2>Manage Students</h2>

<h3>Add / Update Student</h3>
<form id="studentForm">
    <input type="hidden" id="studentId" />
    <label>First Name:</label><br>
    <input type="text" id="firstName" required /><br>

    <label>Last Name:</label><br>
    <input type="text" id="lastName" required /><br>

    <label>Enrollment No:</label><br>
    <input type="text" id="endrollmentno" required /><br><br>

    <button type="submit" id="submitBtn">Add Student</button>
    <button type="button" id="cancelBtn">Cancel</button>
</form>
<h3>All Students</h3>
<div class="search">Search YourSelf: <input type="text" placeholder="enter your first name" id="search" /> </div>
<table border="1" id="studentsTable">
    <thead>
        <tr>
            <th>StudentId</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Enrollment No</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<script>
    let isUpdate = false;

    // Load all students
    function loadStudents() {
        fetch('/Text/GetStudents')
        .then(res => res.json())
        .then(data => {
            const tbody = document.querySelector('#studentsTable tbody');
            tbody.innerHTML = '';

            data.forEach(s => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${s.studentId}</td>
                    <td>${s.firstName}</td>
                    <td>${s.lastName}</td>
                    <td>${s.endrollmentno}</td>
                    <td>
                    
                        <button class="editBtn" data-id="${s.studentId}" data-first="${s.firstName}" data-last="${s.lastName}" data-enroll="${s.endrollmentno}">Edit</button>
                        <button class="deleteBtn" data-id="${s.studentId}">Delete</button>
                    </td>`;
                tbody.appendChild(tr);
            });

            // Attach click events AFTER creating the rows
            document.querySelectorAll('.editBtn').forEach(btn => {
                btn.addEventListener('click', function() {
                    editStudent(
                        this.dataset.id,
                        this.dataset.first,
                        this.dataset.last,
                        this.dataset.enroll
                    );
                });
            });

            document.querySelectorAll('.deleteBtn').forEach(btn => {
                btn.addEventListener('click', function() {
                    deleteStudent(this.dataset.id);
                });
            });
        });
    }

    // Edit student
    function editStudent(id, first, last, enrollment) {
        document.getElementById('studentId').value = id;
        document.getElementById('firstName').value = first;
        document.getElementById('lastName').value = last;
        document.getElementById('endrollmentno').value = enrollment;
        document.getElementById('submitBtn').innerText = 'Update Student';
        isUpdate = true;
    }

    // Delete student
    function deleteStudent(id) {
        if(confirm('Are you sure you want to delete this student?')) {
            fetch(`/Text/DeleteStudent?studentId=${id}`)
            .then(res => res.json())
            .then(() => loadStudents());
        }
    }

    // Add or Update
    document.getElementById('studentForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const id = document.getElementById('studentId').value;
        const first = document.getElementById('firstName').value;
        const last = document.getElementById('lastName').value;
        const enrollment = document.getElementById('endrollmentno').value;

        const url = isUpdate
            ? `/Text/UpdateStudent?studentId=${id}&FirstName=${first}&LastName=${last}&endrollmentno=${enrollment}`
            : `/Text/InsertStudent?FirstName=${first}&LastName=${last}&endrollmentno=${enrollment}`;

        fetch(url)
        .then(res => res.json())
        .then(() => {
            loadStudents();
            document.getElementById('studentForm').reset();
            document.getElementById('submitBtn').innerText = 'Add Student';
            isUpdate = false;
        });
    });

    // Cancel button
    document.getElementById('cancelBtn').addEventListener('click', function() {
        document.getElementById('studentForm').reset();
        document.getElementById('submitBtn').innerText = 'Add Student';
        isUpdate = false;
    });

    // Search students while typing
document.getElementById('search').addEventListener('input', function() {
    const query = this.value.trim();

    // Call API only if something is typed
    fetch(`/Text/Search?FirstName=${encodeURIComponent(query)}`)
        .then(res => res.json())
        .then(data => {
            const tbody = document.querySelector('#studentsTable tbody');
            tbody.innerHTML = '';

            data.forEach(s => {
                const tr = document.createElement('tr');
                tr.innerHTML = `
                    <td>${s.studentId}</td>
                    <td>${s.firstName}</td>
                    <td>${s.lastName}</td>
                    <td>${s.endrollmentno}</td>
                    <td>
                                        <button class="editBtn" data-id="${s.studentId}" data-first="${s.firstName}" data-last="${s.lastName}" data-enroll="${s.endrollmentno}">Edit</button>
                            <button class="deleteBtn" data-id="${s.studentId}">Delete</button>
                    </td>`;
                tbody.appendChild(tr);
            });

            // Re-attach edit and delete events
            document.querySelectorAll('.editBtn').forEach(btn => {
                btn.addEventListener('click', function() {
                    editStudent(
                        this.dataset.id,
                        this.dataset.first,
                        this.dataset.last,
                        this.dataset.enroll
                    );
                });
            });

            document.querySelectorAll('.deleteBtn').forEach(btn => {
                btn.addEventListener('click', function() {
                    deleteStudent(this.dataset.id);
                });
            });
        });
});
    // Initial load
    loadStudents();
</script>