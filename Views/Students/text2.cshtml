@{
    ViewData["Title"] = "Faculty Management";
}

<!DOCTYPE html>
<html>
<head>
    <title>Faculty Management</title>

    <style>

        body {
            font-family: Arial;
            background: #f4f6f9;
            padding: 40px;
        }

        .container {
            width: 700px;
            margin: auto;
            background: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
        }

        .form-group {
            margin-bottom: 15px;
        }

        label {
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 6px;
        }

        button {
            background: #007bff;
            color: white;
            border: none;
            padding: 8px 15px;
            border-radius: 6px;
            cursor: pointer;
        }

            button:hover {
                background: #0056b3;
            }

        table {
            width: 100%;
            margin-top: 20px;
            border-collapse: collapse;
        }

        th {
            background: #007bff;
            color: white;
            padding: 10px;
        }

        td {
            padding: 8px;
            text-align: left;
            border-bottom: 1px solid #ddd;
        }

        .edit-btn {
            background: #28a745;
        }

    </style>

</head>

<body>

    <div class="container">

        <h2>Faculty Management</h2>

        <input type="hidden" id="facultyId">

        <div class="form-group">
            <label>Faculty Name</label>
            <input type="text" id="facultyName">
        </div>

        <div class="form-group">
            <label>Department Name</label>
            <input type="text" id="departmentName">
        </div>

        <button onclick="saveFaculty()" id="saveBtn">Add Faculty</button>

        <table id="facultyTable">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Faculty</th>
                    <th>Department</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody></tbody>

        </table>

    </div>

    <script>

        let isUpdate=false;

        function loadFaculty(){

        fetch('/text2/GetFacultys')
        .then(res=>res.json())
        .then(data=>{

        let tbody=document.querySelector("#facultyTable tbody");
        tbody.innerHTML="";

        data.forEach(f=>{

        let row=`
        <tr>
        <td>${f.facultyId}</td>
        <td>${f.facultyName}</td>
        <td>${f.departmentName}</td>
        <td>
        <button class="edit-btn"
        onclick="editFaculty('${f.facultyId}','${f.facultyName}','${f.departmentName}')">
        Edit
        </button>
        </td>
        </tr>
        `;

        tbody.innerHTML+=row;

        });

        });

        }

        function saveFaculty(){

        let id=document.getElementById("facultyId").value;
        let name=document.getElementById("facultyName").value;
        let dept=document.getElementById("departmentName").value;

        if(isUpdate){

        fetch(`/text2/UpdateFacults?FacultyId=${id}&FacultyName=${name}&DepartmentName=${dept}`)
        .then(res=>res.json())
        .then(data=>{

        alert(data.message);

        clearForm();
        loadFaculty();

        });

        }
        else{

        fetch(`/text2/InsertFaculty?FacultyName=${name}&DepartmentName=${dept}`)
        .then(res=>res.json())
        .then(data=>{

        alert(data.message);

        clearForm();
        loadFaculty();

        });

        }

        }

        function editFaculty(id,name,dept){

        document.getElementById("facultyId").value=id;
        document.getElementById("facultyName").value=name;
        document.getElementById("departmentName").value=dept;

        document.getElementById("saveBtn").innerText="Update Faculty";

        isUpdate=true;

        }

        function clearForm(){

        document.getElementById("facultyId").value="";
        document.getElementById("facultyName").value="";
        document.getElementById("departmentName").value="";

        document.getElementById("saveBtn").innerText="Add Faculty";

        isUpdate=false;

        }

        window.onload=loadFaculty;

    </script>

</body>
</html>